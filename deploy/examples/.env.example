# LeanSpec Cloud Deployment Environment Variables
# Copy to .env and customize for your deployment.

# ── Server ────────────────────────────────────────────────────────────
# Host to bind to (use 0.0.0.0 for containers)
# LEANSPEC_HOST=0.0.0.0

# Port (most cloud platforms set this automatically)
# PORT=3000

# ── Data & Storage ────────────────────────────────────────────────────
# Override the default ~/.lean-spec/ data directory.
# Set this to a persistent volume mount in cloud deployments.
# LEANSPEC_DATA_DIR=/data

# Custom SQLite database URL (resolved relative to LEANSPEC_DATA_DIR)
# DATABASE_URL=sqlite://leanspec.db

# ── Security ──────────────────────────────────────────────────────────
# API key for bearer-token authentication on /api/* routes.
# When set, all API requests require: Authorization: Bearer <key>
# Health endpoints (/health/*) are always exempt.
# LEANSPEC_API_KEY=

# Enable read-only mode (block all write operations)
# LEANSPEC_READONLY=false

# ── Observability ─────────────────────────────────────────────────────
# Log format: "text" (human-readable) or "json" (structured, for log aggregators)
# LEANSPEC_LOG_FORMAT=text

# Log level: trace, debug, info, warn, error
# LEANSPEC_LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated allowed origins (empty = allow all)
# LEANSPEC_CORS_ORIGINS=https://your-domain.com

# ── UI ────────────────────────────────────────────────────────────────
# Path to pre-built UI dist (auto-detected in Docker images)
# LEANSPEC_UI_DIST=/app/ui-dist

# ── Project ───────────────────────────────────────────────────────────
# Auto-register a project directory on startup
# LEANSPEC_PROJECT=/path/to/project

#!/bin/sh
# Format Rust code before commit (fast operation)
echo "🎨 Formatting Rust code..."
cd rust && cargo fmt --all

if [ $? -ne 0 ]; then
  echo "❌ Rust formatting failed!"
  exit 1
fi

# Stage any Rust files that were formatted
git add -u "*.rs" 2>/dev/null || true
cd ..

echo "✅ Rust code formatted!"

# Check that pnpm-lock.yaml doesn't contain platform-specific binaries
# These are generated locally and should not be committed
if grep -q "packages/cli/binaries/" pnpm-lock.yaml 2>/dev/null || \
   grep -q "packages/http-server/binaries/" pnpm-lock.yaml 2>/dev/null; then
  echo "❌ pnpm-lock.yaml contains platform binaries references!"
  echo ""
  echo "This happens when you run 'pnpm install' after building platform binaries."
  echo "To fix, run:"
  echo "  rm -rf packages/cli/binaries/*/ packages/http-server/binaries/*/"
  echo "  git checkout pnpm-lock.yaml"
  echo ""
  exit 1
fi

echo "✅ pnpm-lock.yaml is clean!"

# specs/ is a frozen historical snapshot — new specs go on GitHub Issues.
# Allow deletions (cleanup) and the FROZEN.md marker; block everything else.
specs_changes=$(git diff --cached --name-only --diff-filter=AM | grep -E '^specs/' | grep -v '^specs/FROZEN\.md$' || true)
if [ -n "$specs_changes" ]; then
  echo "❌ specs/ is a frozen historical snapshot. New specs go on GitHub Issues."
  echo "   See AGENTS.md › 'Spec-driven development (GitHub-issue specs)'."
  echo ""
  echo "   Blocked files:"
  echo "$specs_changes" | sed 's/^/     /'
  echo ""
  echo "   Override with --no-verify only if you have a good reason."
  exit 1
fi
